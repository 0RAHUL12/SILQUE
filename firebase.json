{
  "hosting": {
    "public": "public",
    "redirects": [
      {
        "source": "/8x8-airlaid-cocktail-napkins",
        "destination": "/products#cocktail",
        "type": 301
      },
      {
        "source": "/8x8-airlaid-cocktail-napkins/",
        "destination": "/products#cocktail",
        "type": 301
      },
      {
        "source": "/16x16-airlaid-dinner-napkins",
        "destination": "/products#dinner",
        "type": 301
      },
      {
        "source": "/16x16-airlaid-dinner-napkins/",
        "destination": "/products#dinner",
        "type": 301
      },
      {
        "source": "/airlaid-pocket-napkins",
        "destination": "/products#pocket",
        "type": 301
      },
      {
        "source": "/airlaid-pocket-napkins/",
        "destination": "/products#pocket",
        "type": 301
      },
      {
        "source": "/20x20-airlaid-cocktail-napkins",
        "destination": "/products#cocktail",
        "type": 301
      },
      {
        "source": "/20x20-airlaid-cocktail-napkins/",
        "destination": "/products#cocktail",
        "type": 301
      },
      {
        "source": "/40x40-airlaid-dinner-napkins",
        "destination": "/products#dinner",
        "type": 301
      },
      {
        "source": "/40x40-airlaid-dinner-napkins/",
        "destination": "/products#dinner",
        "type": 301
      },
      {
        "source": "/catalogue",
        "destination": "/downloads/silque-airlaid-napkin-catalogue-bengaluru.pdf",
        "type": 301
      },
      {
        "source": "/catalogue/",
        "destination": "/downloads/silque-airlaid-napkin-catalogue-bengaluru.pdf",
        "type": 301
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "headers": [
      {
        "source": "**/*.@(js|css|webp|png|jpg|jpeg|gif|svg|ico|woff|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000, public"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
